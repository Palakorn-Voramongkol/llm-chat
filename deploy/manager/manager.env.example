# /etc/llm-chat/manager.env — owned by llm-chat:llm-chat, mode 0600.
# Copy this to /etc/llm-chat/manager.env and fill in the blanks.

# Manager listen port (only nginx talks to it; bind loopback by default).
MANAGER_PORT=7777

# Number of worker processes the manager will spawn locally.
MANAGER_INSTANCES=1
MANAGER_START_PORT=7878

# Hide the worker GUI (single-server deploys).
MANAGER_STEALTH=1

# Path to the worker binary (set by the deploy step).
LLM_CHAT_EXE=/usr/local/bin/llm-chat-worker

# Cold-start grace period before the first /chat q is processed.
MANAGER_CHAT_WARMUP_SECS=8

# Zitadel auth — required for client → manager.
ZITADEL_ISSUER=https://id.palakorn.com
ZITADEL_AUDIENCE=370627061150121985
ZITADEL_PROJECT_ID=370627061150121985

# Postgres queue (optional — comment out to use the SQLite default).
# MANAGER_DB_URL=postgres://llm_chat:<pw>@127.0.0.1:5432/llm_chat
