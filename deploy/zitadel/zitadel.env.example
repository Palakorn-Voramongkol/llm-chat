# Copy to /etc/zitadel/zitadel.env on the server, then `chmod 600` it.
# Owner: zitadel:zitadel.

# 32-char hex master key. Generate once with: openssl rand -hex 16
# Encrypts secrets at rest. Lose this and you lose access to encrypted data.
ZITADEL_MASTERKEY=

# Public URL (what nginx serves). Tells Zitadel how to build issuer / redirect
# / discovery URLs.
ZITADEL_EXTERNALDOMAIN=id.palakorn.com
ZITADEL_EXTERNALSECURE=true
ZITADEL_EXTERNALPORT=443

# Internal HTTP port. nginx proxies 443 -> 127.0.0.1:8080.
ZITADEL_PORT=8080
ZITADEL_TLS_ENABLED=false

# Postgres connection. Reuses the host's PG 17 on 127.0.0.1:5432.
ZITADEL_DATABASE_POSTGRES_HOST=127.0.0.1
ZITADEL_DATABASE_POSTGRES_PORT=5432
ZITADEL_DATABASE_POSTGRES_DATABASE=zitadel
ZITADEL_DATABASE_POSTGRES_USER_USERNAME=zitadel
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=
ZITADEL_DATABASE_POSTGRES_USER_SSL_MODE=disable

# Admin role used ONLY on first boot to install extensions + create the
# zitadel database. Revoke or rotate after the schema is created.
ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME=postgres
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=
ZITADEL_DATABASE_POSTGRES_ADMIN_SSL_MODE=disable

# First-run admin login (Console at https://id.palakorn.com/ui/console).
# Used only on the very first start; can be deleted from this file afterward.
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=zadmin
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=false
