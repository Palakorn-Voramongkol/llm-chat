{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LLM Chat",
  "version": "0.1.0",
  "identifier": "com.llm-chat.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LLM Chat",
        "width": 900,
        "height": 600,
        "minWidth": 500,
        "minHeight": 300,
        "decorations": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: data:; img-src 'self' tauri: data: blob:; script-src 'self' tauri: 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' tauri: ipc: http://ipc.localhost ws://127.0.0.1:7878; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
