# Connection settings for the llm-chat stack — the SINGLE source of connection
# config for both the host CLIs (clients/{rust,python}) and the Docker services
# (loaded via `env_file:` in docker-compose.yml).
#
# This is a COMMITTED TEMPLATE. The real file is `.env.local` (gitignored).
# `./reset.ps1` / `./reset.sh` regenerate `.env.local` from this template +
# `secrets/` after every seed, so the two reseed-generated IDs below stay in
# sync automatically. To set it up by hand: copy to `.env.local` and fill in
# PROJECT_ID (from secrets/project_id) and OIDC_CLIENT_ID (from
# secrets/oidc_client_id).
#
# SECURITY: connection identifiers ONLY (URLs, hosts, ports, IDs, key PATHS).
# Real secrets — passwords, master keys, session keys, key-file CONTENTS — live
# in `.env` / `secrets/`, never here.

# ── client CLIs (run on the host, from the repo root) ──
ZITADEL_ISSUER=http://host.docker.internal:8080
MANAGER_WS=ws://127.0.0.1:7777/chat
# Regenerated each reseed (filled from secrets/ by the reset scripts):
PROJECT_ID=
OIDC_CLIENT_ID=
# Host path to the machine-user key (the key CONTENTS stay in secrets/):
KABYTECH_KEY=./secrets/kabytech-key.json

# ── manager ──
MANAGER_BIND=0.0.0.0
MANAGER_BACKEND_HOST=host.docker.internal
MANAGER_BACKEND_PORTS=7878
# Friendly project name shown on the clients' /status (else the numeric id):
MANAGER_PROJECT_NAME=llm-chat

# ── admin-api ──
ADMIN_BIND_ADDR=0.0.0.0:7676
# PUBLIC/ALLOWED origin is the proxy/web origin (:3000), NOT the BFF's own port:
# admin-web same-origin-proxies the OIDC nav to the BFF, so the redirect_uri must
# stay on :3000 (must equal the registered :3000/callback) or Zitadel 302s past
# the proxy and drops the pre-auth cookie -> "state mismatch" 403 at /callback.
ADMIN_PUBLIC_ORIGIN=http://localhost:3000
ADMIN_ALLOWED_ORIGIN=http://localhost:3000
# Sessions page reads the manager's /control (SA needs chat.user+chat.admin).
MANAGER_CONTROL_URL=ws://manager:7777/control
# Paths to provisioner-written secret files in the read-only /secrets mount
# (the entrypoint resolves *_FILE -> value). The key CONTENTS stay in secrets/.
ADMIN_SA_KEY_PATH=/secrets/admin-api-key.json
ADMIN_OIDC_CLIENT_ID_FILE=/secrets/admin_oidc_client_id
ADMIN_OIDC_CLIENT_SECRET_FILE=/secrets/admin_oidc_client_secret

# ── admin-web ── (in-network BFF the Next.js rewrites proxy /api,/login,… to)
ADMIN_API_ORIGIN=http://admin-api:7676

# ── kabytech-backend ──
KABY_BIND_ADDR=0.0.0.0:7670
# PUBLIC origin is the FRONTEND origin (:3001): the OIDC redirect_uri is
# {public_origin}/callback and the browser must land on the proxied frontend or
# the SameSite=Lax cookie is dropped (same rule as admin-api above).
KABY_PUBLIC_ORIGIN=http://localhost:3001
KABY_ALLOWED_ORIGIN=http://localhost:3001
KABY_SA_KEY_PATH=/secrets/kabytech-login-key.json

# ── kabytech-frontend ── (in-network backend the frontend proxies to)
KABY_BACKEND_ORIGIN=http://kabytech-backend:7670
